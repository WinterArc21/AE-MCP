# AE MCP — environment variables
# Copy to .env and adjust, or set in your shell / MCP client config.

# Override the commands folder (default: ~/Documents/ae-mcp-commands)
# Use when Documents is redirected (e.g. OneDrive) or you want a custom path.
# Both the MCP server and CEP panel read this — Node syncs it to ~/Documents/ae-mcp-commands-dir.txt
# AE_MCP_COMMANDS_DIR=/path/to/your/ae-mcp-commands
